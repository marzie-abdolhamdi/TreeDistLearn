  set autoclose=yes nowarn=yes;

  lset nst=1 rates=equal;
  prset brlenspr=unconstrained:exp(10.0);

  mcmcp nruns=1 ngen=500000 samplefreq=500 printfreq=5000 diagnfreq=5000 nchains=4 temp=0.2 burninfrac=0.25 stoprule=yes stopval=0.01;

