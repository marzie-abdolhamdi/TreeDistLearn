#NEXUS
begin data;
dimensions ntax=10 nchar=1000;
format datatype=dna missing=? gap=-;
matrix
Taxon_9 
Taxon_2 
Taxon_7 
Taxon_5 
Taxon_4 
Taxon_3 
Taxon_1 
Taxon_0 
Taxon_8 
Taxon_6 
;
end;
begin mrbayes;
  set autoclose=yes nowarn=yes;

  lset nst=6 rates=gamma;

  [~1000 trees per run: 200000/200 = 1000]
  mcmcp nruns=2 nchains=4 ngen=200000 samplefreq=200 printfreq=1000 diagnfreq=5000 burninfrac=0.25;

  mcmc;
  sump;
  sumt;
end;
