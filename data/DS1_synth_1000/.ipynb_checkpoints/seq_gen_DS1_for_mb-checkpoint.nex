#NEXUS

BEGIN DATA;
	DIMENSIONS NTAX=27 NCHAR=1000;
	FORMAT DATATYPE=DNA MISSING=? GAP=-;
	MATRIX
	Alligator_mississippiensis 
	Trachemys_scripta    
	Amphiuma_tridactylum 
	Grandisonia_alternans 
	Hypogeophis_rostratus 
	Homo_sapiens         
	Mus_musculus         
	Rattus_norvegicus    
	Sceloporus_undulatus 
	Heterodon_platyrhinos 
	Ambystoma_mexicanum  
	Siren_intermedia     
	Scaphiopus_holbrooki 
	Plethodon_yonhalossee 
	Discoglossus_pictus  
	Hyla_cinerea         
	Eleutherodactylus_cuneatus 
	Xenopus_laevis       
	Latimeria_chalumnae  
	Typhlonectes_natans  
	Gallus_gallus        
	Turdus_migratorius   
	Nesomantis_thomasseti 
	Oryctolagus_cuniculus 
	Ichthyophis_bannanicus 
	Bufo_valliceps       
	Gastrophryne_carolinensis 
	;
END;

BEGIN MRBAYES;
	set autoclose=yes nowarn=yes;
	lset nst=1 rates=equal;
	prset brlenspr=unconstrained:exp(10.0) statefreqpr=fixed(equal);
	mcmcp ngen=2000000 samplefreq=1000 burninfrac=0.25 nchains=4 printfreq=50000 diagnfreq=10000;
	mcmc;
	sumt burnin=500;
	sump burnin=500;
	quit;
END;
