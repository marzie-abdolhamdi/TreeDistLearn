#NEXUS
begin data;
dimensions ntax=27 nchar=1000;
format datatype=dna missing=? gap=-;
matrix
Alligator_mississippiensis 
Trachemys_scripta          
Amphiuma_tridactylum       
Grandisonia_alternans      
Hypogeophis_rostratus      
Homo_sapiens               
Mus_musculus               
Rattus_norvegicus          
Sceloporus_undulatus       
Heterodon_platyrhinos      
Ambystoma_mexicanum        
Siren_intermedia           
Scaphiopus_holbrooki       
Plethodon_yonhalossee      
Discoglossus_pictus        
Hyla_cinerea               
Eleutherodactylus_cuneatus 
Xenopus_laevis             
Latimeria_chalumnae        
Typhlonectes_natans        
Gallus_gallus              
Turdus_migratorius         
Nesomantis_thomasseti      
Oryctolagus_cuniculus      
Ichthyophis_bannanicus     
Bufo_valliceps             
Gastrophryne_carolinensis  
;
end;

BEGIN MRBAYES;
    [Set Jukes-Cantor model: equal rates (nst=1) and equal base frequencies]
    lset nst=1;
    prset statefreqpr=fixed(equal);
    
    [Run MCMC]
    mcmc ngen=100000 samplefreq=100 printfreq=1000 diagnfreq=10000 file=mb_posterior;
    
    [Summarize trees and parameters, discarding 25% burn-in]
    sumt burnin=250;
    sump burnin=250;
    
    quit;
END;
