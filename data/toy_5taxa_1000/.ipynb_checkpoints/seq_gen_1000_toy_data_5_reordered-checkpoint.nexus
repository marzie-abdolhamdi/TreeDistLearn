#NEXUS
begin data;
dimensions ntax=5 nchar=1000;
format datatype=dna missing=? gap=-;
matrix
Taxon1 
Taxon2 
Taxon5 
Taxon4 
Taxon3 
;
end;

BEGIN MRBAYES;
    [Set Jukes-Cantor model: equal rates (nst=1) and equal base frequencies]
    lset nst=1;
    prset statefreqpr=fixed(equal);
    
    [Run MCMC]
    mcmc ngen=100000 samplefreq=100 printfreq=1000 diagnfreq=10000 file=mb_posterior_toy;
    
    [Summarize trees and parameters, discarding 25% burn-in]
    sumt burnin=250;
    sump burnin=250;
    
    quit;
END;
