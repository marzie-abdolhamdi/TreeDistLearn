#NEXUS

BEGIN DATA;
	DIMENSIONS NTAX=5 NCHAR=1000;
	FORMAT DATATYPE=DNA MISSING=? GAP=-;
	MATRIX
	Taxon1               
	Taxon4               
	Taxon5               
	Taxon3               
	Taxon2               
	;
END;

BEGIN MRBAYES;
	set autoclose=yes nowarn=yes;
	lset nst=1 rates=equal;
	prset brlenspr=unconstrained:exp(10.0) statefreqpr=fixed(equal);
	mcmcp ngen=500000 samplefreq=500 burninfrac=0.25 nchains=4 printfreq=10000 diagnfreq=5000;
	mcmc;
	sumt burnin=250;
	sump burnin=250;
	quit;
END;
